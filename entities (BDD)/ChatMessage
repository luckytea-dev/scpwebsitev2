{
  "name": "ChatMessage",
  "type": "object",
  "properties": {
    "app": {
      "type": "string",
      "enum": [
        "SPIN",
        "MTF"
      ],
      "default": "SPIN"
    },
    "channel_id": {
      "type": "string",
      "default": "general"
    },
    "content": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "author_id": {
      "type": "string"
    },
    "min_clearance": {
      "type": "number",
      "default": 1
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "content",
    "app",
    "channel_id"
  ]
}